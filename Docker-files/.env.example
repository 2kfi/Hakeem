# ============================================
# LLMSIMT-Hakeem - Simplified Environment Variables
# ============================================
# Only override what you need. Most settings work out of the box.

# --------------------------------------------
# PRESET (default/lightweight/heavy)
# --------------------------------------------
PRESET=default

# --------------------------------------------
# Application
# --------------------------------------------
APP_HOST=0.0.0.0
APP_PORT=8003
APP_LOG_LEVEL=INFO

# --------------------------------------------
# STT (Speech-to-Text) - Override if needed
# --------------------------------------------
# STT_REPO=Systran/faster-whisper
# STT_MODEL=medium
# STT_DEVICE=auto
# STT_COMPUTE_TYPE=int8

# For local model (overrides repo):
# STT_MODEL_PATH=models/my-whisper

# --------------------------------------------
# TTS (Text-to-Speech) - English
# --------------------------------------------
# TTS_EN_REPO=rhasspy/piper-voices
# TTS_EN_VOICE=en_GB/cori/high

# For local model (overrides repo):
# TTS_EN_MODEL_PATH=models/my-voice.onnx
# TTS_EN_CONFIG_PATH=models/my-voice.onnx.json

# --------------------------------------------
# TTS (Text-to-Speech) - Arabic
# --------------------------------------------
# TTS_AR_REPO=rhasspy/piper-voices
# TTS_AR_VOICE=ar_JO/kareem/medium

# For local model (overrides repo):
# TTS_AR_MODEL_PATH=models/my-voice.onnx
# TTS_AR_CONFIG_PATH=models/my-voice.onnx.json

# --------------------------------------------
# TTS Settings
# --------------------------------------------
# TTS_VOLUME=0.5
# TTS_FRAMERATE=24000

# --------------------------------------------
# LLM (Large Language Model) (OpenAI-API)
# --------------------------------------------
LLM_API_URL=http://10.200.71.180:2312/v1
LLM_API_KEY=sk-no-key-required

# --------------------------------------------
# MCP Servers (comma-separated)
# --------------------------------------------
MCP_SERVER_URLS=http://10.200.71.180:2527/sse,http://10.200.71.180:2528/sse
MCP_MAX_RETRIES=2

# --------------------------------------------
# Models
# --------------------------------------------
# MODELS_STORAGE_PATH=./models
# MODELS_DOWNLOAD_ON_STARTUP=true
