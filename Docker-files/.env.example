# Application Settings
APP_HOST=0.0.0.0
APP_PORT=8003
APP_LOG_LEVEL=INFO

# STT (Speech-to-Text) - Whisper
STT_MODEL_PATH=models/whisper-medium
STT_VARIANT=medium
STT_DEVICE=auto
STT_COMPUTE_TYPE=int8
STT_BEAM_SIZE=5
STT_VAD_FILTER=true

# TTS (Text-to-Speech) - English
TTS_EN_MODEL=models/TTS-CORI-EN/en_GB-cori-high.onnx
TTS_EN_CONFIG=models/TTS-CORI-EN/en_GB-cori-high.onnx.json

# TTS (Text-to-Speech) - Arabic
TTS_AR_MODEL=models/TTS-KAREEM-ARABIC/ar_JO-kareem-medium.onnx
TTS_AR_CONFIG=models/TTS-KAREEM-ARABIC/ar_JO-kareem-medium.onnx.json

# TTS Settings
TTS_VOLUME=0.5
TTS_LENGTH_SCALE=1.0
TTS_NOISE_SCALE=1.0
TTS_NOISE_W_SCALE=1.0
TTS_NORMALIZE_AUDIO=false
TTS_NCHANNELS=1
TTS_SAMPWIDTH=2
TTS_FRAMERATE=24000

# LLM (Large Language Model)
LLM_API_URL=http://10.200.71.180:2312/v1
LLM_API_KEY=sk-no-key-required

# MCP (Model Context Protocol) Servers
MCP_SERVER_URLS=http://10.200.71.180:2527/sse,http://10.200.71.180:2528/sse
MCP_MAX_RETRIES=2

# Models
MODELS_STORAGE_PATH=./models
MODELS_DOWNLOAD_ON_STARTUP=false
