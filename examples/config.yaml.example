# Full Configuration Example
# Copy this file to config.yaml and modify as needed

models:
  storage_path: "/app/models"
  download_on_startup: false

app:
  host: "0.0.0.0"
  port: 8003
  log_level: "INFO"

# Speech-to-Text (Whisper)
stt:
  model: "Systran/faster-whisper-medium"
  device: "auto"
  compute_type: "int8"
  beam_size: 5
  vad_filter: true
  vad_threshold: 0.5
  vad_min_speech_ms: 250
  vad_min_silence_ms: 200

# Text-to-Speech
# Each language: repo (HF), voice (path), local_path (override)
tts:
  en:
    repo: "rhasspy/piper-voices"
    voice: "en_GB/cori/high"
    local_path: null
  ar:
    repo: "speaches-ai/piper-ar_JO-kareem-medium"
    local_path: null

# Audio output settings (applies to all TTS languages)
settings:
  volume: 0.5
  length_scale: 1.0
  noise_scale: 1.0
  noise_w_scale: 1.0
  normalize_audio: false
  nchannels: 1
  sampwidth: 2
  framerate: 24000

# Language Model (LLM)
llm:
  api_url: "http://localhost:2312/v1"
  api_key: "sk-no-key-required"
  model: "local-model"

# MCP Servers (for knowledge base)
mcp:
  servers:
    - "http://localhost:2527/sse"
    - "http://localhost:2528/sse"
  max_retries: 2