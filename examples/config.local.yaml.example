# Local/Bare-Metal Configuration
# Use this when running without Docker
# Paths are relative to project root

models:
  storage_path: "./models"
  download_on_startup: false

app:
  host: "0.0.0.0"
  port: 8003
  log_level: "INFO"

# STT - use local model folder
stt:
  model: "./models/whisper-medium"
  device: "cpu"
  compute_type: "int8"
  beam_size: 5

# TTS - use local model folders
tts:
  en:
    repo: null
    voice: null
    local_path: "./models/TTS-CORI-EN"
  ar:
    repo: null
    voice: null
    local_path: "./models/TTS-KAREEM-ARABIC"

settings:
  volume: 0.5
  length_scale: 1.0
  noise_scale: 1.0
  noise_w_scale: 1.0
  normalize_audio: false
  nchannels: 1
  sampwidth: 2
  framerate: 24000

# LLM - local server
llm:
  api_url: "http://localhost:2312/v1"
  api_key: "sk-no-key-required"
  model: "local-model"

# MCP - local servers
mcp:
  servers:
    - "http://localhost:2527/sse"
    - "http://localhost:2528/sse"
  max_retries: 2