# Docker Deployment Configuration
# Volumes are mounted at /app in container
# Copy to config.yaml when running with Docker

models:
  storage_path: "/app/models"
  download_on_startup: false

app:
  host: "0.0.0.0"
  port: 8003
  log_level: "INFO"

# STT - compatible with Docker volumes
stt:
  model: "Systran/faster-whisper-medium"
  device: "auto"
  compute_type: "int8"
  beam_size: 5

# TTS - use local paths (volumes mounted at /app/models)
tts:
  en:
    repo: "rhasspy/piper-voices"
    voice: "en_GB/cori/high"
    local_path: "/app/models/EN"
  ar:
    repo: "speaches-ai/piper-ar_JO-kareem-medium"
    local_path: "/app/models/AR"

settings:
  volume: 0.5
  length_scale: 1.0
  noise_scale: 1.0
  noise_w_scale: 1.0
  normalize_audio: false
  nchannels: 1
  sampwidth: 2
  framerate: 24000

# Point to host machine services
llm:
  api_url: "http://host.docker.internal:2312/v1"
  api_key: "sk-no-key-required"
  model: "local-model"

mcp:
  servers:
    - "http://host.docker.internal:2527/sse"
    - "http://host.docker.internal:2528/sse"
  max_retries: 2