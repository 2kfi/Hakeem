# Environment Variables (optional overrides)
# Copy to .env and modify

# App settings
# PRESET=default
# PORT=8003
# LOG_LEVEL=INFO

# STT settings
# STT_DEVICE=auto
# STT_COMPUTE_TYPE=int8
# STT_MODEL=Systran/faster-whisper-medium

# TTS settings
# TTS_VOLUME=0.5
# TTS_LENGTH_SCALE=1.0
# TTS_FRAMERATE=24000

# LLM settings
# LLM_API_URL=http://localhost:2312/v1
# LLM_API_KEY=sk-no-key-required

# MCP settings
# MCP_SERVER_URLS=http://localhost:2527/sse,http://localhost:2528/sse